<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>제곱의 합 3D 시각화 증명 (순차 조립)</title>
    <!-- Tailwind CSS for UI -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Three.js for 3D Rendering -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
        body { margin: 0; overflow: hidden; background-color: #121212; color: #ffffff; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        #canvas-container { width: 100vw; height: 100vh; display: block; position: absolute; top: 0; left: 0; z-index: 1; }
        #ui-layer { position: relative; z-index: 10; pointer-events: none; width: 100%; height: 100%; display: flex; justify-content: flex-end; padding: 1.5rem; }
        .ui-panel {
            pointer-events: auto;
            background: rgba(30, 30, 35, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1rem;
            padding: 1.5rem;
            width: 340px;
            height: fit-content;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
        }
        
        button:disabled { opacity: 0.5; cursor: not-allowed; }
        
        /* 3D 라벨용 스타일 추가 */
        .dim-label {
            position: absolute;
            background: rgba(15, 23, 42, 0.4);
            color: rgba(96, 165, 250, 0.85);
            padding: 4px 10px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 0.95rem;
            border: 1px solid rgba(96, 165, 250, 0.25);
            transform: translate(-50%, -50%);
            transition: opacity 0.2s;
            pointer-events: none;
            backdrop-filter: blur(2px);
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <div id="canvas-container"></div>

    <!-- 3D 캔버스 위에 표시될 길이 라벨 컨테이너 -->
    <div id="labels-container" class="pointer-events-none absolute inset-0 z-20 overflow-hidden">
        <div id="label-w" class="dim-label opacity-0"></div>
        <div id="label-h" class="dim-label opacity-0"></div>
        <div id="label-d" class="dim-label opacity-0"></div>
    </div>

    <div id="ui-layer">
        <div class="ui-panel">
            <div class="flex justify-between items-center mb-1">
                <h1 class="text-xl font-bold text-white">∑k² 시각적 증명</h1>
                <button id="btn-toggle-ui" class="text-gray-400 hover:text-white focus:outline-none" title="UI 최소화/최대화">
                    <svg id="icon-collapse" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    <svg id="icon-expand" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>
                </button>
            </div>
            
            <div id="ui-collapsible-top">
                <p class="text-xs text-gray-400 mb-4">6개의 직각 피라미드가 원형을 유지하며 맞물립니다.</p>

                <!-- n 값 조절 버튼형 UI -->
                <div class="mb-4">
                    <div class="flex justify-between items-center mb-2">
                        <label class="text-sm font-semibold">피라미드 크기 (n)</label>
                    </div>
                    <div class="flex items-center justify-between bg-black/40 rounded-lg p-1.5 border border-white/10">
                        <button id="btn-n-dec" class="px-4 py-1 bg-gray-700 hover:bg-gray-600 rounded text-white font-bold transition-colors">-</button>
                        <span id="n-display" class="font-bold text-lg text-blue-400">3</span>
                        <button id="btn-n-inc" class="px-4 py-1 bg-gray-700 hover:bg-gray-600 rounded text-white font-bold transition-colors">+</button>
                    </div>
                </div>
            </div>

            <!-- 개별 조립/분해 버튼 (항상 표시) -->
            <div class="grid grid-cols-2 gap-2 my-2">
                <button id="btn-step-assemble" class="bg-blue-600 hover:bg-blue-500 transition-colors py-2 rounded text-sm font-bold shadow-lg">
                    1번 조립하기
                </button>
                <button id="btn-step-disassemble" class="bg-gray-700 hover:bg-gray-600 transition-colors py-2 rounded text-sm font-bold shadow-lg" disabled>
                    분해 완료
                </button>
            </div>

            <div id="ui-collapsible-bottom">
                <!-- 모두 조립/분해 버튼 -->
                <div class="grid grid-cols-2 gap-2 mb-4 mt-4">
                    <button id="btn-all-assemble" class="bg-blue-800 hover:bg-blue-700 transition-colors py-2 rounded text-sm font-bold shadow-lg border border-blue-500/30">
                        모두 조립
                    </button>
                    <button id="btn-all-disassemble" class="bg-gray-800 hover:bg-gray-700 transition-colors py-2 rounded text-sm font-bold shadow-lg border border-gray-500/30">
                        모두 분해
                    </button>
                </div>

                <div class="bg-black/30 rounded-lg p-3 text-sm space-y-2 border border-white/5">
                    <div class="flex justify-between items-center">
                        <span class="text-gray-300">1개 피라미드 (Σk²):</span>
                        <span id="val-pyramid" class="font-mono font-bold text-white">14</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-gray-300">총 6개 블록 수:</span>
                        <span id="val-total" class="font-mono font-bold text-white">84</span>
                    </div>
                    <div class="border-t border-gray-600/50 my-1"></div>
                    <div class="flex justify-between items-center text-xs text-gray-400">
                        <span>직육면체 공식:</span>
                        <span>n(n+1)(2n+1)</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-gray-300">목표 크기 (가로x세로x높이):</span>
                        <span id="val-box" class="font-mono font-bold text-white">3x4x7</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-gray-300">목표 총 부피:</span>
                        <span id="val-box-vol" class="font-mono font-bold text-blue-400">84</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let scene, camera, renderer, controls, masterGroup;
        let groups = [];
        
        // Raycaster 및 목표 박스(호버 효과)용 변수
        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2(-1, -1);
        let targetBoxMesh, hitBoxMesh, edgesHelper;
        let targetCenter = new THREE.Vector3();
        
        const blockGeo = new THREE.BoxGeometry(0.96, 0.96, 0.96);
        const colors = [0xff595e, 0xffca3a, 0x8ac926, 0x1982c4, 0x6a4c93, 0xeb5e28];
        const materials = colors.map(c => new THREE.MeshPhysicalMaterial({ 
            color: c, metalness: 0.1, roughness: 0.4, clearcoat: 0.2
        }));

        let currentN = 3;
        let currentStep = 0; // 0 (모두 분해됨) ~ 6 (모두 조립됨)
        let autoAnimInterval = null;

        window.onload = function() {
            init3D();
            setupUI();
            createModel(currentN);
            animate();
        };

        function init3D() {
            const container = document.getElementById('canvas-container');

            scene = new THREE.Scene();
            scene.fog = new THREE.FogExp2(0x121212, 0.012);

            camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(25, 18, 30);

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            container.appendChild(renderer.domElement);

            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.maxPolarAngle = Math.PI / 2 + 0.05;

            const ambientLight = new THREE.AmbientLight(0xffffff, 0.65);
            scene.add(ambientLight);

            const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
            dirLight.position.set(15, 30, 15);
            dirLight.castShadow = true;
            dirLight.shadow.mapSize.width = 2048;
            dirLight.shadow.mapSize.height = 2048;
            dirLight.shadow.camera.near = 0.5;
            dirLight.shadow.camera.far = 100;
            const d = 20;
            dirLight.shadow.camera.left = -d; dirLight.shadow.camera.right = d;
            dirLight.shadow.camera.top = d; dirLight.shadow.camera.bottom = -d;
            scene.add(dirLight);

            const planeGeo = new THREE.PlaneGeometry(200, 200);
            const planeMat = new THREE.ShadowMaterial({ opacity: 0.3 });
            const plane = new THREE.Mesh(planeGeo, planeMat);
            plane.rotation.x = -Math.PI / 2;
            plane.position.y = -0.48; 
            plane.receiveShadow = true;
            scene.add(plane);

            const gridHelper = new THREE.GridHelper(100, 100, 0x444444, 0x222222);
            gridHelper.position.y = -0.47;
            scene.add(gridHelper);

            masterGroup = new THREE.Group();
            masterGroup.rotation.x = -Math.PI / 2;
            scene.add(masterGroup);

            // 마우스 이동 이벤트 리스너 추가
            window.addEventListener('mousemove', (e) => {
                mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
                mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
            });

            window.addEventListener('resize', onWindowResize, false);
        }

        function getQuat(ux, uy, uz) {
            const m = new THREE.Matrix4();
            m.set(
                ux[0], uy[0], uz[0], 0,
                ux[1], uy[1], uz[1], 0,
                ux[2], uy[2], uz[2], 0,
                0,     0,     0,     1
            );
            return new THREE.Quaternion().setFromRotationMatrix(m);
        }

        function createModel(n) {
            groups.forEach(g => masterGroup.remove(g));
            groups = [];
            currentStep = 0;
            clearAutoAnim();
            updateControlsUI();
            
            // 기존 생성된 타겟 박스 및 헬퍼 제거
            if (targetBoxMesh) scene.remove(targetBoxMesh);
            if (hitBoxMesh) scene.remove(hitBoxMesh);
            if (edgesHelper) scene.remove(edgesHelper);

            const cx = (n - 1) / 2;
            const cy = n / 2;
            const cz = 0; 
            
            const pivot = new THREE.Vector3((n - 1) / 2, (n - 1) / 2, (n - 1) / 2);

            const configs = [
                { ux: [1, 0, 0], uy: [0, 1, 0], uz: [0, 0, 1], T: [0, 0, 0] },
                { ux: [0, 0, -1], uy: [1, 0, 0], uz: [0, -1, 0], T: [0, n, n - 1] },
                { ux: [0, 1, 0], uy: [0, 0, -1], uz: [-1, 0, 0], T: [n - 1, 0, n] },
                { ux: [0, 0, 1], uy: [0, -1, 0], uz: [1, 0, 0], T: [0, n, n] },
                { ux: [-1, 0, 0], uy: [0, 0, 1], uz: [0, 1, 0], T: [n - 1, 0, n + 1] },
                { ux: [0, -1, 0], uy: [-1, 0, 0], uz: [0, 0, -1], T: [n - 1, n, 2 * n] }
            ];

            let totalBlocks = 0;

            for (let p = 0; p < 6; p++) {
                const group = new THREE.Group();
                
                const angle = p * (Math.PI / 3);
                const radius = n * 2.2;
                const startX = Math.cos(angle) * radius;
                const startY = Math.sin(angle) * radius;
                const startPos = new THREE.Vector3(startX, startY, pivot.z);
                const startQuat = new THREE.Quaternion().identity();

                const config = configs[p];
                const targetQuat = getQuat(config.ux, config.uy, config.uz);
                const targetPosOld = new THREE.Vector3(config.T[0] - cx, config.T[1] - cy, config.T[2] - cz);
                const targetPos = targetPosOld.clone().add(pivot.clone().applyQuaternion(targetQuat));

                group.position.copy(startPos);
                group.quaternion.copy(startQuat);
                
                // 각 그룹별로 독립적인 애니메이션 진행률과 목표값 저장
                group.userData = { 
                    startPos, targetPos, startQuat, targetQuat, localIndex: p,
                    animProgress: 0, animTarget: 0 
                };

                for (let z = 0; z < n; z++) {
                    const k = n - z;
                    for (let x = 0; x < k; x++) {
                        for (let y = 0; y < k; y++) {
                            const mesh = new THREE.Mesh(blockGeo, materials[p]);
                            mesh.position.set(x - pivot.x, y - pivot.y, z - pivot.z);
                            mesh.castShadow = true;
                            mesh.receiveShadow = true;
                            group.add(mesh);
                            totalBlocks++;
                        }
                    }
                }

                masterGroup.add(group);
                groups.push(group);
            }

            // --- 조립 완료 상태의 중심점(바운딩 박스) 계산 ---
            groups.forEach(g => {
                g.position.copy(g.userData.targetPos);
                g.quaternion.copy(g.userData.targetQuat);
            });
            masterGroup.updateMatrixWorld(true);
            
            const box3 = new THREE.Box3().setFromObject(masterGroup);
            box3.getCenter(targetCenter);
            
            // 블록 원위치 복구
            groups.forEach(g => {
                g.position.copy(g.userData.startPos);
                g.quaternion.copy(g.userData.startQuat);
            });
            masterGroup.updateMatrixWorld(true);

            // 호버 시 나타날 반투명 목표 직육면체 (크기: n x 2n+1 x n+1)
            const targetGeo = new THREE.BoxGeometry(n, 2 * n + 1, n + 1);
            targetBoxMesh = new THREE.Mesh(
                targetGeo,
                new THREE.MeshBasicMaterial({ color: 0x4299e1, transparent: true, opacity: 0, depthWrite: false, side: THREE.DoubleSide })
            );
            targetBoxMesh.position.copy(targetCenter);
            scene.add(targetBoxMesh);

            // 목표 직육면체의 모서리 와이어프레임
            edgesHelper = new THREE.LineSegments(
                new THREE.EdgesGeometry(targetGeo),
                new THREE.LineBasicMaterial({ color: 0x90cdf4, transparent: true, opacity: 0, linewidth: 2 })
            );
            edgesHelper.position.copy(targetCenter);
            scene.add(edgesHelper);

            // 레이캐스트 충돌 감지용 투명 박스 (마우스 호버 인식 영역)
            hitBoxMesh = new THREE.Mesh(
                new THREE.BoxGeometry(n + 1, 2 * n + 2, n + 2),
                new THREE.MeshBasicMaterial({ visible: false })
            );
            hitBoxMesh.position.copy(targetCenter);
            scene.add(hitBoxMesh);

            // 길이 라벨 텍스트 초기화
            document.getElementById('label-w').textContent = `n = ${n}`;
            document.getElementById('label-h').textContent = `2n+1 = ${2 * n + 1}`;
            document.getElementById('label-d').textContent = `n+1 = ${n + 1}`;

            updateUIInfo(n, totalBlocks);
        }

        function easeInOutCubic(x) {
            return x < 0.5 ? 4 * x * x * x : 1 - Math.pow(-2 * x + 2, 3) / 2;
        }

        function animate() {
            requestAnimationFrame(animate);

            const stepSize = 0.02; // 조립 애니메이션 속도

            groups.forEach((group) => {
                let { animProgress, animTarget, startPos, targetPos, startQuat, targetQuat, localIndex } = group.userData;

                if (animProgress !== animTarget) {
                    if (animProgress < animTarget) {
                        group.userData.animProgress = Math.min(animProgress + stepSize, animTarget);
                    } else {
                        group.userData.animProgress = Math.max(animProgress - stepSize, animTarget);
                    }
                    
                    const t = easeInOutCubic(group.userData.animProgress);

                    group.position.lerpVectors(startPos, targetPos, t);
                    group.quaternion.slerpQuaternions(startQuat, targetQuat, t);

                    if (t > 0 && t < 1) {
                        const distance = startPos.distanceTo(targetPos);
                        const arcHeight = Math.sin(t * Math.PI) * (distance * 0.2 + localIndex * 0.4);
                        group.position.z += arcHeight;
                    }
                }
            });

            // 마우스 호버 감지 및 효과 업데이트
            if (hitBoxMesh) {
                raycaster.setFromCamera(mouse, camera);
                const intersects = raycaster.intersectObject(hitBoxMesh);
                const isHovered = intersects.length > 0;
                
                // 목표 박스와 모서리의 투명도를 부드럽게 보간
                const targetOpacity = isHovered ? 0.12 : 0;
                const edgeOpacity = isHovered ? 0.6 : 0;
                targetBoxMesh.material.opacity += (targetOpacity - targetBoxMesh.material.opacity) * 0.1;
                edgesHelper.material.opacity += (edgeOpacity - edgesHelper.material.opacity) * 0.1;

                if (isHovered) {
                    document.getElementById('label-w').style.opacity = '0.75';
                    document.getElementById('label-h').style.opacity = '0.75';
                    document.getElementById('label-d').style.opacity = '0.75';
                    
                    const n = currentN;
                    
                    // 각 모서리의 중심 3D 좌표를 2D 화면 좌표로 투영
                    // W (가로 n): 바닥면 앞쪽 모서리 중앙
                    updateLabelPos('label-w', new THREE.Vector3(targetCenter.x, targetCenter.y - (2*n+1)/2, targetCenter.z + (n+1)/2));
                    // H (높이 2n+1): 우측면 앞쪽 모서리 중앙
                    updateLabelPos('label-h', new THREE.Vector3(targetCenter.x + n/2, targetCenter.y, targetCenter.z + (n+1)/2));
                    // D (세로 n+1): 바닥면 우측 모서리 중앙
                    updateLabelPos('label-d', new THREE.Vector3(targetCenter.x + n/2, targetCenter.y - (2*n+1)/2, targetCenter.z));
                } else {
                    document.getElementById('label-w').style.opacity = '0';
                    document.getElementById('label-h').style.opacity = '0';
                    document.getElementById('label-d').style.opacity = '0';
                }
            }

            controls.update();
            renderer.render(scene, camera);
        }

        // 3D 좌표를 브라우저 픽셀 좌표로 변환하여 DOM 요소 이동
        function updateLabelPos(id, worldPos) {
            const vec = worldPos.clone().project(camera);
            const x = (vec.x * 0.5 + 0.5) * window.innerWidth;
            const y = (vec.y * -0.5 + 0.5) * window.innerHeight;
            const el = document.getElementById(id);
            el.style.left = `${x}px`;
            el.style.top = `${y}px`;
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function clearAutoAnim() {
            if (autoAnimInterval) {
                clearInterval(autoAnimInterval);
                autoAnimInterval = null;
            }
        }

        function updateControlsUI() {
            const btnAssemble = document.getElementById('btn-step-assemble');
            const btnDisassemble = document.getElementById('btn-step-disassemble');

            if (currentStep < 6) {
                btnAssemble.textContent = `${currentStep + 1}번 조립하기`;
                btnAssemble.disabled = false;
            } else {
                btnAssemble.textContent = `조립 완료`;
                btnAssemble.disabled = true;
            }

            if (currentStep > 0) {
                btnDisassemble.textContent = `${currentStep}번 분해하기`;
                btnDisassemble.disabled = false;
            } else {
                btnDisassemble.textContent = `분해 완료`;
                btnDisassemble.disabled = true;
            }
        }

        function setupUI() {
            const btnNInc = document.getElementById('btn-n-inc');
            const btnNDec = document.getElementById('btn-n-dec');
            const nDisplay = document.getElementById('n-display');
            
            const btnAssemble = document.getElementById('btn-step-assemble');
            const btnDisassemble = document.getElementById('btn-step-disassemble');
            const btnAllAssemble = document.getElementById('btn-all-assemble');
            const btnAllDisassemble = document.getElementById('btn-all-disassemble');

            // UI 토글 요소
            const btnToggleUI = document.getElementById('btn-toggle-ui');
            const uiTop = document.getElementById('ui-collapsible-top');
            const uiBottom = document.getElementById('ui-collapsible-bottom');
            const iconCollapse = document.getElementById('icon-collapse');
            const iconExpand = document.getElementById('icon-expand');
            
            let isUIMinimized = false;

            btnToggleUI.addEventListener('click', () => {
                isUIMinimized = !isUIMinimized;
                if (isUIMinimized) {
                    uiTop.classList.add('hidden');
                    uiBottom.classList.add('hidden');
                    iconCollapse.classList.add('hidden');
                    iconExpand.classList.remove('hidden');
                } else {
                    uiTop.classList.remove('hidden');
                    uiBottom.classList.remove('hidden');
                    iconCollapse.classList.remove('hidden');
                    iconExpand.classList.add('hidden');
                }
            });

            // N 크기 조절
            btnNInc.addEventListener('click', () => {
                if (currentN < 6) {
                    currentN++;
                    nDisplay.textContent = currentN;
                    createModel(currentN);
                }
            });

            btnNDec.addEventListener('click', () => {
                if (currentN > 2) {
                    currentN--;
                    nDisplay.textContent = currentN;
                    createModel(currentN);
                }
            });

            // 개별 단계 조립
            btnAssemble.addEventListener('click', () => {
                clearAutoAnim();
                if (currentStep < 6) {
                    groups[currentStep].userData.animTarget = 1;
                    currentStep++;
                    updateControlsUI();
                }
            });

            // 개별 단계 분해
            btnDisassemble.addEventListener('click', () => {
                clearAutoAnim();
                if (currentStep > 0) {
                    currentStep--;
                    groups[currentStep].userData.animTarget = 0;
                    updateControlsUI();
                }
            });

            // 모두 조립 (순차적 연출)
            btnAllAssemble.addEventListener('click', () => {
                clearAutoAnim();
                autoAnimInterval = setInterval(() => {
                    if (currentStep < 6) {
                        groups[currentStep].userData.animTarget = 1;
                        currentStep++;
                        updateControlsUI();
                    } else {
                        clearAutoAnim();
                    }
                }, 250); // 250ms 간격으로 순차 조립
            });

            // 모두 분해 (순차적 연출)
            btnAllDisassemble.addEventListener('click', () => {
                clearAutoAnim();
                autoAnimInterval = setInterval(() => {
                    if (currentStep > 0) {
                        currentStep--;
                        groups[currentStep].userData.animTarget = 0;
                        updateControlsUI();
                    } else {
                        clearAutoAnim();
                    }
                }, 250); // 250ms 간격으로 순차 분해
            });
        }

        function updateUIInfo(n, totalBlocks) {
            const pyramidVol = totalBlocks / 6;
            const w = n, d = n + 1, h = 2 * n + 1;
            
            document.getElementById('val-pyramid').textContent = pyramidVol;
            document.getElementById('val-total').textContent = totalBlocks;
            document.getElementById('val-box').textContent = `${w} x ${d} x ${h}`;
            document.getElementById('val-box-vol').textContent = w * d * h;
        }
    </script>
</body>
</html>
